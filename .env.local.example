# SpireOps — Environment Variables Template
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — bypasses RLS. SERVER-SIDE ONLY.
# Found in: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Google Gemini API ─────────────────────────────────────────
# Obtain from: https://aistudio.google.com/app/apikey
# Used by: POST /api/ocr-receipt
GEMINI_API_KEY=your-gemini-api-key-here

# ── Next.js ───────────────────────────────────────────────────
# Set to your production domain when deploying
NEXTAUTH_URL=http://localhost:3000
